{
  "manifest_version": 3,

  "name": "Phishing Email Detector",

  "version": "1.0",

  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],

  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "https://mail.google.com/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ],

  "action": {
    "default_popup": "popup.html"
  }
}